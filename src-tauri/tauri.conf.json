{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Luma",
  "version": "0.1.0",
  "identifier": "com.aamirkhan.luma",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns"
    ],
    "copyright": "Made with passion by Aamir Alsufi",
    "publisher": "Aamir Alsufi"
  }
}